generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String            @id @default(cuid())
  email          String            @unique
  name           String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  watchlists     Watchlist[]
  portfolios     Portfolio[]
  aiReports      AIReport[]
  notionExports  NotionExport[]
}

model Asset {
  id             String          @id @default(cuid())
  symbol         String          @unique
  assetType      AssetType
  sector         String?
  theme          String?
  exchange       String?
  currency       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  prices         Price[]
  indicators     Indicator[]
  signals        Signal[]
  aiReports      AIReport[]
  strategyLogs   StrategyLog[]
  riskLogs       RiskLog[]
  watchlists     Watchlist[]
  portfolioItems PortfolioItem[]
}

model Watchlist {
  id            String    @id @default(cuid())
  userId        String
  assetId       String
  priority      Int       @default(3)
  holdingStatus String?
  riskLevel     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset         Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model Portfolio {
  id          String          @id @default(cuid())
  userId      String
  name        String
  baseCurrency String        @default("USD")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       PortfolioItem[]
  riskLogs    RiskLog[]
}

model PortfolioItem {
  id          String    @id @default(cuid())
  portfolioId String
  assetId     String
  weight      Float
  quantity    Float?
  avgPrice    Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset       Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model Price {
  id         String   @id @default(cuid())
  assetId     String
  timestamp  DateTime
  open       Float?
  high       Float?
  low        Float?
  close      Float
  volume     Float?
  source     String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, timestamp])
}

model Indicator {
  id           String   @id @default(cuid())
  assetId       String
  timestamp    DateTime
  rsi          Float?
  macd         Float?
  sma20        Float?
  sma50        Float?
  volatility   Float?
  breadth      Float?
  asset        Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, timestamp])
}

model NewsItem {
  id           String   @id @default(cuid())
  symbol       String?
  title        String
  summary      String?
  sentiment    Float?
  publishedAt  DateTime
  source       String
}

model AIReport {
  id                String   @id @default(cuid())
  userId            String
  assetId           String
  summary           String
  technicalView     String
  fundamentalView   String
  riskView          String
  actionLabel       ActionLabel
  confidenceScore   Int
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset             Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model Signal {
  id           String   @id @default(cuid())
  assetId       String
  signalType   String
  value        Float
  score        Int
  createdAt    DateTime @default(now())
  asset        Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model StrategyLog {
  id            String   @id @default(cuid())
  assetId        String
  strategyName  String
  result        String
  winRate       Float?
  drawdown      Float?
  notes         String?
  createdAt     DateTime @default(now())
  asset         Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model RiskLog {
  id             String    @id @default(cuid())
  assetId         String?
  portfolioId     String?
  level          RiskLevel
  summary        String
  createdAt      DateTime  @default(now())
  asset          Asset?    @relation(fields: [assetId], references: [id], onDelete: SetNull)
  portfolio      Portfolio? @relation(fields: [portfolioId], references: [id], onDelete: SetNull)
}

model NotionExport {
  id             String   @id @default(cuid())
  userId         String
  exportType     String
  targetDatabase String
  payload        Json
  status         String
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AssetType {
  equity
  crypto
  etf
  fx
  macro
}

enum ActionLabel {
  BUY_CANDIDATE
  HOLD
  WATCH
  REDUCE_RISK
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}
